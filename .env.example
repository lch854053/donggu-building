# 공공데이터포털 서비스키 (디코딩된 키)
BLD_SERVICE_KEY=your_data_go_kr_building_service_key
APT_SERVICE_KEY=your_data_go_kr_apartment_service_key
ARCH_SERVICE_KEY=your_data_go_kr_archpms_service_key
HSPMS_SERVICE_KEY=your_data_go_kr_hspms_service_key

# 오픈데이터 (odcloud) 폴백 키 — 국토교통부 건축인허가 실패 시 동구 건축허가현황 API용
ODCLOUD_SERVICE_KEY=your_odcloud_service_key

# 카카오 — 로컬 키워드 검색 API (공동주택명 보정용)
KAKAO_REST_API_KEY=your_kakao_rest_api_key
